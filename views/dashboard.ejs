<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Dashboard</title>
</head>
<body>

    <h1>Welcome, <%= user.email %></h1>
    <p>Your Dashboard</p>

    <hr>

    <!-- Upload to Root -->
    <h2>Upload File (Root)</h2>
    <form action="/files" method="POST" enctype="multipart/form-data">
        <input type="file" name="file" required>
        <button type="submit">Upload</button>
    </form>

    <hr>

    <!-- Upload to Specific Folder -->
    <h2>Upload to Folder</h2>

    <% if (folders && folders.length > 0) { %>
        <form action="/files/folder/<%= folders[0].id %>" 
              method="POST" 
              enctype="multipart/form-data">

            <select name="folderId"
                    onchange="this.form.action='/files/folder/' + this.value">
                <% folders.forEach(folder => { %>
                    <option value="<%= folder.id %>">
                        <%= folder.name %>
                    </option>
                <% }) %>
            </select>

            <input type="file" name="file" required>
            <button type="submit">Upload</button>
        </form>
    <% } else { %>
        <p>No folders available.</p>
    <% } %>

    <hr>

    <!-- Files List -->
    <h2>Your Files</h2>

    <% if (!files || files.length === 0) { %>
        <p>No files uploaded yet.</p>
    <% } %>

    <% files.forEach(file => { %>
        <div style="margin-bottom: 20px;">
            
            <strong><%= file.name %></strong> 
            (<%= (file.size / 1024).toFixed(2) %> KB)

            <br>
            <a href="<%= file.url %>" target="_blank">View</a>

            <!-- Rename -->
            <form action="/files/<%= file.id %>?_method=PUT" method="POST" style="margin-top: 5px;">
                <input type="text" name="name" placeholder="New name" required>
                <button type="submit">Rename</button>
            </form>

            <!-- Delete -->
            <form action="/files/<%= file.id %>?_method=DELETE" method="POST" style="margin-top: 5px;">
                <button type="submit">Delete</button>
            </form>

        </div>
        <hr>
    <% }) %>

</body>
</html>