<!DOCTYPE html>
<html>
<head>
    <title>Edit Folder</title>
</head>
<body>
    <%- include("../sections/navbar") %>

    <h1>Edit Folder</h1>

    <form action="/folders/<%= folder.id %>?_method=PUT" method="POST">

        <input 
            type="text"
            name="name"
            value="<%= folder.name %>"
            required
        >

        <button type="submit">Update</button>

    </form>

    <br>

    <a href="/folders">Back</a>

    <%- include("../sections/footer") %>

</body>
</html>