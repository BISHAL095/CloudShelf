<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= folder.name %></title>
</head>
<body>

<%- include("../sections/navbar") %>

<h1>📁 <%= folder.name %></h1>

<hr>

<h2>Upload File to This Folder</h2>

<form action="/files/folder/<%= folder.id %>" method="POST" enctype="multipart/form-data">
    <input type="file" name="file" required>
    <button type="submit">Upload</button>
</form>

<hr>

<h2>Files in this Folder</h2>

<% if (!folder.files || folder.files.length === 0) { %>
    <p>No files inside this folder.</p>
<% } %>

<% folder.files.forEach(file => { %>

<div>

<strong>📄 <%= file.name %></strong>
(<%= (file.size / 1024).toFixed(2) %> KB)

<br>

<a href="<%= file.url %>" target="_blank">View</a>

<form action="/files/<%= file.id %>?_method=DELETE" method="POST">
    <button type="submit">Delete</button>
</form>

</div>

<hr>

<% }) %>

<a href="/dashboard">⬅ Back to Dashboard</a>

<%- include("../sections/footer") %>

</body>
</html>