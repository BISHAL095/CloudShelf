<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title><%= folder.name %> | CloudShelf</title>
<link rel="stylesheet" href="/css/style.css">
<link rel="stylesheet" href="/css/loader.css">
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gradient-to-br from-slate-50 to-blue-50 min-h-screen flex flex-col text-gray-800">

<%- include("../sections/navbar") %>

<main class="flex-grow">

<div class="max-w-5xl mx-auto p-6">

<h1 class="text-3xl font-bold mb-2">📁 <%= folder.name %></h1>
<p class="mb-6 text-gray-600">Folder Files</p>

<hr class="border-gray-200 mb-8">

<h2 class="text-2xl font-semibold mb-4">Upload File</h2>

<form id="uploadForm" action="/files/folder/<%= folder.id %>" method="POST" enctype="multipart/form-data"
class="bg-white border border-gray-100 shadow-lg rounded-xl p-6 flex flex-col space-y-4">

<input type="file" name="file" id="fileInput" required
class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">

<input type="text" name="customName" id="nameInput" placeholder="Enter file name"
class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 hidden">

<button type="submit"
class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-lg transition shadow-sm hover:shadow-md">
Upload
</button>

</form>

<hr class="border-gray-200 my-8">

<h2 class="text-2xl font-semibold mb-4">Files in this Folder</h2>

<% if (!folder.files || folder.files.length === 0) { %>
<p class="text-gray-600 mb-6">No files uploaded yet.</p>
<% } %>

<% folder.files.forEach(file => { %>

<div class="bg-white border border-gray-100 p-4 rounded-xl shadow-sm hover:shadow-md transition mb-4 flex items-center justify-between">

<div>
<strong class="text-gray-800">📄 <%= file.name %></strong>
<span class="text-gray-500 text-sm">
(<%= (file.size / 1024).toFixed(2) %> KB)
</span>
<br>

<a href="<%= file.url %>" target="_blank"
class="text-blue-600 text-sm hover:underline">
View
</a>

</div>

<div class="flex items-center space-x-3 text-lg">

<button onclick="openRename('<%= file.id %>', '<%= file.name %>')" class="text-gray-500 hover:text-blue-600">
✏️
</button>

<form class="deleteFileForm" action="/files/<%= file.id %>?_method=DELETE" method="POST">
<button type="submit" class="text-red-500 hover:text-red-700">
🗑️
</button>
</form>

</div>

</div>

<% }) %>

<hr class="border-gray-200 my-8">

<a href="/folders" class="text-gray-600 hover:text-gray-900 underline">
⬅ Back to Folders
</a>

</div>

</main>

<!-- Reusable Loader -->
<div id="loader" class="loader hidden"></div>

<%- include("../sections/footer") %>

<script src="/js/rename.js"></script>
<script src="/js/upload.js"></script>
<script src="/js/loader.js"></script>

<script>
document.addEventListener("DOMContentLoaded", () => {

const uploadForm = document.getElementById('uploadForm');
if(uploadForm){
uploadForm.addEventListener('submit', () => {
showLoader();
});
}

const deleteForms = document.querySelectorAll('.deleteFileForm');
deleteForms.forEach(form => {
form.addEventListener('submit', () => {
showLoader();
});
});

});
</script>

</body>
</html>