<!DOCTYPE html>
<html>
<head>
<title>Your Folders | CloudShelf</title>
<link rel="stylesheet" href="/css/style.css">
<link rel="stylesheet" href="/css/loader.css">
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gradient-to-br from-slate-50 to-blue-50 min-h-screen flex flex-col text-gray-800">

<%- include("../sections/navbar") %>

<main class="flex-grow">

<div class="max-w-5xl mx-auto p-6">

<h1 class="text-3xl font-bold mb-6">📁 Your Folders</h1>

<a href="/folders/new" class="inline-block mb-5">
<button class="bg-green-500 text-white px-5 py-2 rounded-lg hover:bg-green-600 transition shadow-sm hover:shadow-md">
Create Folder
</button>
</a>

<% if (!folders || folders.length === 0) { %>
<p class="text-gray-600 mb-6">No folders created yet.</p>
<% } %>

<% folders.forEach(folder => { %>

<div class="flex items-center justify-between bg-white border border-gray-100 p-4 rounded-xl shadow-sm hover:shadow-md transition mb-3">

<span class="text-gray-700">
📁 <strong><%= folder.name %></strong>
</span>

<div class="flex items-center space-x-4">

<a href="/folders/<%= folder.id %>" class="text-blue-600 font-medium hover:underline">
Open
</a>

<a href="/folders/<%= folder.id %>/edit" class="text-yellow-500 hover:underline">
Edit
</a>

<form class="deleteFolderForm" action="/folders/<%= folder.id %>?_method=DELETE" method="POST">
<button type="submit" class="text-red-500 hover:text-red-700">
Delete
</button>
</form>

</div>

</div>

<% }) %>

</div>

</main>

<!-- Reusable Loader -->
<div id="loader" class="loader hidden"></div>

<%- include("../sections/footer") %>

<script src="/js/loader.js"></script>

<script>
document.addEventListener("DOMContentLoaded", () => {

const deleteForms = document.querySelectorAll('.deleteFolderForm');

deleteForms.forEach(form => {
form.addEventListener('submit', () => {
showLoader();
});
});

});
</script>

</body>
</html>