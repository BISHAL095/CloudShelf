<!DOCTYPE html>
<html>
<head>
<title>Create Folder | CloudShelf</title>
<link rel="stylesheet" href="/css/style.css">
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gradient-to-br from-slate-50 to-blue-50 min-h-screen text-gray-800">

<%- include("../sections/navbar") %>

<div class="max-w-5xl mx-auto p-6">

<h1 class="text-3xl font-bold mb-6">📁 Create New Folder</h1>

<form action="/folders" method="POST"
class="bg-white border border-gray-100 shadow-lg rounded-xl p-6 flex flex-col space-y-4 max-w-md">

<input type="text" name="name" placeholder="Folder name" required
class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">

<button type="submit"
class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-lg transition shadow-sm hover:shadow-md">
Create Folder
</button>

</form>

<a href="/folders" class="inline-block mt-6 text-gray-600 hover:text-gray-900 underline">
← Back
</a>

</div>

<%- include("../sections/footer") %>

</body>
</html>